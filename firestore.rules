rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // Global Safety Net Default-Deny
    match /{document=**} {
      allow read, write: if false;
    }
    
    // Hardened Global Helpers
    function isSignedIn() {
      return request.auth != null;
    }
    
    function isEmailVerified() {
      return isSignedIn() && request.auth.token.email_verified == true;
    }
    
    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }

    // User Profile matching uid
    match /users/{userId} {
      allow get: if isSignedIn() && request.auth.uid == userId;
      allow create, update: if isEmailVerified() && request.auth.uid == userId && isValidId(userId);
      allow list, delete: if false;
    }

    // Subscriptions
    match /subscriptions/{subscriptionId} {
      allow read: if isSignedIn() && resource.data.userEmail == request.auth.token.email;
      allow create, update: if isEmailVerified() && request.resource.data.userEmail == request.auth.token.email && isValidId(subscriptionId);
      allow delete: if false;
    }

    // Bookings
    match /bookings/{bookingId} {
      allow read: if isSignedIn() && resource.data.userEmail == request.auth.token.email;
      allow create, update: if isEmailVerified() && request.resource.data.userEmail == request.auth.token.email && isValidId(bookingId);
      allow delete: if false;
    }
  }
}
